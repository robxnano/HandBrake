$(eval $(call import.MODULE.defs,ZLIB,zlib))
$(eval $(call import.CONTRIB.defs,ZLIB,cmake))

ZLIB.FETCH.url     = https://github.com/zlib-ng/zlib-ng/archive/refs/tags/2.2.4.tar.gz
ZLIB.FETCH.sha256  = a73343c3093e5cdc50d9377997c3815b878fd110bf6511c2c7759f2afb90f5a3
ZLIB.FETCH.basename = zlib-ng-2.2.4.tar.gz

ZLIB.build_dir     = build

ZLIB.CONFIGURE.extra += -DWITH_GTEST=OFF -DZLIB_COMPAT=ON -DZLIB_ENABLE_TESTS=OFF -DZLIBNG_ENABLE_TESTS=OFF
