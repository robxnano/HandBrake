{
  "name": "libbluray",
  "version": "1.3.4",
  "description": "Blu-ray playback library",
  "homepage": "https://www.videolan.org/developers/libbluray.html",
  "license": "LGPL-2.1-or-later",
  "supports": "!uwp & !xbox",
  "dependencies": [
    {
      "name": "vcpkg-cmake",
      "host": true
    }
  ],
  "features": {
    "libxml2": {
      "description": "Build with libxml2",
      "dependencies": [
        "libxml2"
      ]
    },
    "fontconfig": {
      "description": "Build with fontconfig",
      "dependencies": [
        "fontconfig"
      ]
    },
    "freetype": {
      "description": "Build with freetype",
      "dependencies": [
        "freetype"
      ]
    }
  }
}
