$(eval $(call import.MODULE.rules,HB))

build: hb.build
install: hb.install
install-strip: hb.install-strip
uninstall: hb.uninstall
clean: hb.clean
xclean: hb.xclean

hb.configure: $(HB.SETUP.stamp)

$(HB.SETUP.stamp): | $(HB.d) $(BUILD/)GNUmakefile
	$(HB.CONFIGURE.env) $(MESON.exe) setup \
		$(call fn.ABSOLUTE,$(HB.build/)) $(call fn.ABSOLUTE,$(HB.src/)) $(HB.CONFIGURE.extra) $(HB.CONFIGURE.cross)

$(HB.CONFIGURE.stamp): $(BUILD/)GNUmakefile | $(HB.SETUP.stamp)
	$(MESON.exe) configure --clearcache $(call fn.ABSOLUTE,$(HB.build/)) $(HB.CONFIGURE.extra)
	$(TOUCH.exe) $(call fn.ABSOLUTE,$(HB.CONFIGURE.stamp))

hb.reconfigure: | $(HB.SETUP.stamp)
	$(MESON.exe) setup --reconfigure \
		$(call fn.ABSOLUTE,$(HB.build/)) $(call fn.ABSOLUTE,$(HB.src/)) $(HB.CONFIGURE.extra)

hb.build: | $(HB.SETUP.stamp) $(HB.CONFIGURE.stamp)
	+$(NINJA.exe) $(HB.BUILD.extra)

hb.test:
	$(NINJA.exe) test $(HB.BUILD.extra)

hb.install-strip:
	$(MESON.exe) install --strip --tags runtime,i18n

hb.install:
	$(MESON.exe) install --tags runtime,i18n

hb.uninstall:
	$(NINJA.exe) uninstall

hb.clean:
	-$(NINJA.exe) clean

hb.xclean: hb.clean
	-rm -r $(call fn.ABSOLUTE,$(HB.build/))meson-info
	-rm -r $(call fn.ABSOLUTE,$(HB.build/))meson-logs
	-rm -r $(call fn.ABSOLUTE,$(HB.build/))meson-private
	-$(RM.exe) $(HB.SETUP.stamp)
	-rm $(HB.CONFIGURE.stamp)
